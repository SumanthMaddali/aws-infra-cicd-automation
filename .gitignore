# Terraform - only ignore generated files, not .tf source files
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Jenkins
jenkins/workspace/
jenkins/jobs/*/workspace/
jenkins/jobs/*/builds/
.jenkins/

# AWS credentials - never commit these!
.aws/credentials
.aws/config
aws-credentials.json

# IDE
.vscode/
.idea/

# Node.js
node_modules/
app/node_modules/
npm-debug.log
yarn-error.log

# App build output
app/dist/
app/build/

# Docker
docker-compose.override.yml

# Environment files
.env
.env.local
.env.*.local

# Monitoring logs
monitoring/logs/
monitoring/*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.log
*.bak
*.backup
.cache/
temp/
tmp/